,{"id":"data_models/commit_message_contract.md#25","metadata":{"content":"rada (fuera de este gate)","okf_concept":"data_models/commit_message_contract.md","okf_type":"Data Model","title":"Convención de formato de mensaje de commit"}},{"id":"data_models/commit_message_contract.md#26","metadata":{"content":"ada (fuera de este gate)","okf_concept":"data_models/commit_message_contract.md","okf_type":"Data Model","title":"Convención de formato de mensaje de commit"}},{"id":"data_models/commit_message_contract.md#27","metadata":{"content":"da (fuera de este gate)","okf_concept":"data_models/commit_message_contract.md","okf_type":"Data Model","title":"Convención de formato de mensaje de commit"}},{"id":"data_models/commit_message_contract.md#28","metadata":{"content":"a (fuera de este gate)","okf_concept":"data_models/commit_message_contract.md","okf_type":"Data Model","title":"Convención de formato de mensaje de commit"}},{"id":"data_models/commit_message_contract.md#29","metadata":{"content":"(fuera de este gate)","okf_concept":"data_models/commit_message_contract.md","okf_type":"Data Model","title":"Convención de formato de mensaje de commit"}},{"id":"data_models/commit_message_contract.md#3","metadata":{"content":"l |\n\n## Frontera declarada (fuera de este gate)","okf_concept":"data_models/commit_message_contract.md","okf_type":"Data Model","title":"Convención de formato de mensaje de commit"}},{"id":"data_models/commit_message_contract.md#30","metadata":{"content":"(fuera de este gate)","okf_concept":"data_models/commit_message_contract.md","okf_type":"Data Model","title":"Convención de formato de mensaje de commit"}},{"id":"data_models/commit_message_contract.md#31","metadata":{"content":"fuera de este gate)","okf_concept":"data_models/commit_message_contract.md","okf_type":"Data Model","title":"Convención de formato de mensaje de commit"}},{"id":"data_models/commit_message_contract.md#32","metadata":{"content":"uera de este gate)","okf_concept":"data_models/commit