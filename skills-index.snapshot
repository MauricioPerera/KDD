ules.md#26","metadata":{"content":"d, determinista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#27","metadata":{"content":", determinista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#28","metadata":{"content":"determinista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#29","metadata":{"content":"determinista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#3","metadata":{"content":"on pura: sin IO, sin red, determinista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#30","metadata":{"content":"eterminista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#31","metadata":{"content":"terminista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#32","metadata":{"content":"erminista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#33","metadata":{"content":"rminista.\"\"\"\n```","okf_concept":"contracts/validate-rules.md","okf_type":"Task Contract","title":"Motor de reglas declarativo (rule contract)"}},{"id":"contracts/validate-rules.md#34","metadata":{"content":"minista.\"